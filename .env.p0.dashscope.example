# GustoBot-v2 P0 生产替换实验配置示例（通义千问 / DashScope）
# 复制为 .env 或注入到部署环境后，把所有 your-dashscope-api-key 替换为真实密钥。
# 不要把真实 API Key 提交到仓库。

GUSTOBOT_ENV=prod
GUSTOBOT_STRICT_EXTERNAL_STORES=true

# PostgreSQL / Neo4j / Redis：P0 strict 模式禁止退回内存、SQLite 或 seed 数据。
GUSTOBOT_POSTGRES_DSN=postgresql://gustobot:gustobot@127.0.0.1:5432/gustobot
GUSTOBOT_TEXT2SQL_POSTGRES_DSN=postgresql://gustobot:gustobot@127.0.0.1:5432/gustobot
GUSTOBOT_TEXT2SQL_SCHEMA_TABLE=schema_catalog
GUSTOBOT_NEO4J_URI=bolt://127.0.0.1:17687
GUSTOBOT_NEO4J_USERNAME=neo4j
GUSTOBOT_NEO4J_PASSWORD=change-me
GUSTOBOT_REDIS_URL=redis://127.0.0.1:6379/0

# DashScope OpenAI-compatible Chat：Router / Text2SQL / Answer / Vision 共用同一套通义千问账号。
GUSTOBOT_ROUTER_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GUSTOBOT_ROUTER_LLM_API_KEY=your-dashscope-api-key
GUSTOBOT_ROUTER_LLM_MODEL=qwen3-max
GUSTOBOT_TEXT2SQL_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GUSTOBOT_TEXT2SQL_LLM_API_KEY=your-dashscope-api-key
GUSTOBOT_TEXT2SQL_LLM_MODEL=qwen3-max
GUSTOBOT_ANSWER_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GUSTOBOT_ANSWER_LLM_API_KEY=your-dashscope-api-key
GUSTOBOT_ANSWER_LLM_MODEL=qwen3-max
GUSTOBOT_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GUSTOBOT_VISION_API_KEY=your-dashscope-api-key
GUSTOBOT_VISION_MODEL=qwen-image-2.0-pro

# DashScope Embedding：text-embedding-v4 输出维度为 1024。
GUSTOBOT_KB_EMBEDDING_PROVIDER=openai-compatible
GUSTOBOT_KB_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GUSTOBOT_KB_EMBEDDING_API_KEY=your-dashscope-api-key
GUSTOBOT_KB_EMBEDDING_MODEL=text-embedding-v4
GUSTOBOT_KB_EMBEDDING_DIMENSION=1024

# DashScope Rerank：qwen3-rerank 使用 DashScope rerank 服务入口。
GUSTOBOT_KB_RERANK_BASE_URL=https://dashscope.aliyuncs.com/api/v1/services
GUSTOBOT_KB_RERANK_ENDPOINT=/rerank/text-rerank/text-rerank
GUSTOBOT_KB_RERANK_API_KEY=your-dashscope-api-key
GUSTOBOT_KB_RERANK_MODEL=qwen3-rerank
GUSTOBOT_KB_RERANK_FORMAT=auto

# GustoBot-develop 变量映射参考：
# LLM_*       -> GUSTOBOT_ROUTER_LLM_* / GUSTOBOT_TEXT2SQL_LLM_* / GUSTOBOT_ANSWER_LLM_* / GUSTOBOT_VISION_*
# EMBEDDING_* -> GUSTOBOT_KB_EMBEDDING_*
# RERANK_*    -> GUSTOBOT_KB_RERANK_*
# VISION_*    -> GUSTOBOT_VISION_*
