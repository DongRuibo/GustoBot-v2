# GustoBot-v2 本地配置示例。
# 复制为 .env 后可被 docker compose 读取；不要把真实 API Key 提交到代码仓库。

# 默认使用 hash embedding，方便 Docker E2E 不依赖外部模型服务。
# 切真实 embedding 时再改为 openai-compatible，并配置 BASE_URL/API_KEY/MODEL。
GUSTOBOT_KB_EMBEDDING_PROVIDER=hash
GUSTOBOT_KB_EMBEDDING_BASE_URL=
GUSTOBOT_KB_EMBEDDING_API_KEY=
GUSTOBOT_KB_EMBEDDING_MODEL=hash-embedding
GUSTOBOT_KB_EMBEDDING_DIMENSION=1024
GUSTOBOT_KB_EMBEDDING_TIMEOUT_SECONDS=30
GUSTOBOT_KB_RERANK_BASE_URL=
GUSTOBOT_KB_RERANK_ENDPOINT=/rerank
GUSTOBOT_KB_RERANK_MODEL=bge-reranker
GUSTOBOT_KB_RERANK_FORMAT=auto
GUSTOBOT_KB_RERANK_MAX_RETRIES=1

# v2 新知识库表结构：kb_documents + kb_chunks。
# 宿主机直接运行 scripts/prepare_kb_data.py 时，连接 Docker 暴露到本机的端口。
GUSTOBOT_POSTGRES_DSN=postgresql://gustobot:gustobot@127.0.0.1:5432/gustobot
GUSTOBOT_KB_PGVECTOR_TABLE=kb_chunks

# 可选：LLM Router。未配置时走规则 Router；生产建议 temperature=0。
GUSTOBOT_ROUTER_LLM_ENABLED=true
GUSTOBOT_ROUTER_LLM_PROVIDER=openai-compatible
GUSTOBOT_ROUTER_LLM_BASE_URL=
GUSTOBOT_ROUTER_LLM_API_KEY=
GUSTOBOT_ROUTER_LLM_MODEL=
GUSTOBOT_ROUTER_LLM_TIMEOUT_SECONDS=15
GUSTOBOT_ROUTER_LLM_TEMPERATURE=0
GUSTOBOT_ROUTER_LLM_MAX_RETRIES=1

# 可选：使用阿里云百炼调优后的 Router 模型时启用 DashScope 原生调用。
# GUSTOBOT_ROUTER_LLM_PROVIDER=dashscope
# GUSTOBOT_ROUTER_LLM_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# GUSTOBOT_ROUTER_LLM_API_KEY=your-dashscope-api-key
# GUSTOBOT_ROUTER_LLM_MODEL=your-deployment-model-id

# Text2SQL 使用 PostgreSQL 只读链路。生产环境建议为这里配置只读账号。
GUSTOBOT_TEXT2SQL_POSTGRES_DSN=postgresql://gustobot:gustobot@127.0.0.1:5432/gustobot
GUSTOBOT_TEXT2SQL_SCHEMA_TABLE=schema_catalog
GUSTOBOT_TEXT2SQL_LLM_BASE_URL=
GUSTOBOT_TEXT2SQL_LLM_API_KEY=
GUSTOBOT_TEXT2SQL_LLM_MODEL=
GUSTOBOT_TEXT2SQL_LLM_TEMPERATURE=0

# Docker 版 Neo4j / Redis。宿主机直连可改为 127.0.0.1，容器内使用服务名。
GUSTOBOT_NEO4J_URI=bolt://neo4j:7687
GUSTOBOT_NEO4J_USERNAME=neo4j
GUSTOBOT_NEO4J_PASSWORD=gustobotneo4j
GUSTOBOT_REDIS_URL=redis://redis:6379/0

# 上传文件默认落在 data/uploads；只允许通过 upload://file_id 被后端解析。
GUSTOBOT_UPLOAD_DIR=data/uploads
GUSTOBOT_UPLOAD_MAX_MB=20
GUSTOBOT_ALLOWED_FILE_EXTENSIONS=.txt,.md,.json,.csv,.xlsx,.xls,.pdf,.doc,.docx
GUSTOBOT_ALLOWED_IMAGE_EXTENSIONS=.jpg,.jpeg,.png,.webp,.bmp

# 可选：统一答案生成层。未配置时会使用确定性 fallback 并追加 Evidence 来源。
GUSTOBOT_ANSWER_LLM_BASE_URL=
GUSTOBOT_ANSWER_LLM_API_KEY=
GUSTOBOT_ANSWER_LLM_MODEL=
GUSTOBOT_ANSWER_LLM_MAX_RETRIES=1
GUSTOBOT_ALLOW_GENERAL_RECIPE_FALLBACK=true

# 可选：图片理解与 OCR。Vision/OCR 只生成结构化文本，随后重新进入 Router。
GUSTOBOT_VISION_BASE_URL=
GUSTOBOT_VISION_API_KEY=
GUSTOBOT_VISION_MODEL=qwen3-vl-plus
GUSTOBOT_VISION_MAX_RETRIES=1
GUSTOBOT_OCR_BASE_URL=
GUSTOBOT_OCR_API_KEY=
GUSTOBOT_OCR_MODEL=
GUSTOBOT_OCR_MAX_RETRIES=1

# 可选：Docker smoke 质量断言。接入真实服务后打开，用于确认配置真正生效。
GUSTOBOT_SMOKE_EXPECT_EMBEDDING_PROVIDER=
GUSTOBOT_SMOKE_EXPECT_RERANKER_SUCCESS=false
GUSTOBOT_SMOKE_EXPECT_ANSWER_MODE=
GUSTOBOT_SMOKE_EXPECT_REAL_DATA=false

# 兼容旧 GustoBot-develop：如果已经有以下变量，也可以不改名直接使用。
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=bge-m3
# EMBEDDING_API_KEY=your-embedding-api-key
# EMBEDDING_BASE_URL=http://your-embedding-host:9997/v1
# EMBEDDING_DIMENSION=1024
# LLM_BASE_URL=http://your-chat-host/v1
# LLM_API_KEY=your-chat-api-key
# LLM_MODEL=qwen3-max
# RERANK_BASE_URL=http://your-rerank-host
# RERANK_ENDPOINT=/reranks
# RERANK_MODEL=qwen3-rerank
# PGHOST=localhost
# PGPORT=5432
# PGDATABASE=vector_db
# PGUSER=postgres
# PGPASSWORD=postgres
# GUSTOBOT_KB_PGVECTOR_TABLE=searchable_documents
